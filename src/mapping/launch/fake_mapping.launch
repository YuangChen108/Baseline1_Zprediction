<launch>
  <node pkg="nodelet" type="nodelet" name="manager" args="manager" output="screen">
    <param name="num_worker_threads" value="16"/>
  </node>

  <include file="$(find uav_simulator)/launch/uav_simulator.launch">
    <arg name="init_x_" value="0"/>
    <arg name="init_y_" value="0"/>
    <arg name="init_z_" value="1"/>
  </include>

  <node pkg="nodelet" type="nodelet" name="mapping" args="load mapping/Nodelet manager" output="screen">
    <!-- camera parameters -->
    <rosparam command="load" file="$(find mapping)/config/camera.yaml"/>
    <!-- remap topics -->
    <remap from="~gridmap_inflate" to="gridmap_inflate"/>
    <!-- mapping parameters -->
    <param name="resolution" value="0.1"/>
    <param name="local_x" value="0.1"/>
    <param name="local_y" value="0.1"/>
    <param name="local_z" value="0.1"/>
    <param name="inflate_size" value="0"/>
    <param name="near_size" value="0"/>
    <!-- fake parameters -->
    <param name="fake_mapping" value="true"/>
  </node>
</launch>